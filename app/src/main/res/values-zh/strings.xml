    <string name="help_item_create_note_title">创建笔记</string>
    <string name="help_item_create_note_steps">点击“笔记”屏幕上的悬浮 + 按钮。\n输入标题并开始在内容字段中输入内容。\n按下返回箭头 —— 笔记将自动保存。</string>
    <string name="help_item_checklist_title">创建清单笔记</string>
    <string name="help_item_checklist_steps">打开或创建一个笔记。\n点击底部操作栏中的复选框图标。\n开启清单开关。\n在单独的行中输入每个项目，点击复选框进行勾选。</string>
    <string name="help_item_rich_text_title">富文本格式（加粗、倾斜、项目符号）</string>
    <string name="help_item_rich_text_steps">选择内容空间中的文本。\n点击底部操作栏中的“文本格式”图标。\n底部会出现文本格式工具栏。\n点击加粗、倾斜、下划线或项目符号列表进行应用。</string>
    <string name="help_item_attachments_title">添加图片、音频或视频</string>
    <string name="help_item_attachments_steps">打开或创建一个笔记。\n点击底部操作栏中的附件（回形针）图标。\n选择相机、相册、音频或视频。\n媒体文件将以内联方式显示在笔记中。</string>
    <string name="help_item_reminder_title">设置笔记提醒</string>
    <string name="help_item_reminder_steps">打开或创建一个笔记。\n点击底部操作栏中的铃声（提醒）图标。\n选择日期和时间。\n闹钟已安排，笔记上会出现提醒徽章。</string>
    <string name="help_item_share_note_title">分享笔记</string>
    <string name="help_item_share_note_steps">打开您想要分享的笔记。\n点击“更多”菜单（三个点）。\n点击“分享”。\n选择用于分享的应用（电子邮件、消息应用等）。</string>
    <string name="help_item_collaborate_title">与他人协作</string>
    <string name="help_item_collaborate_steps">登录 Google 并在“设置”中启用 CloudSync。\n打开笔记并点击“更多”菜单（三个点）。\n点击“协作”。\n输入协作者的电子邮件并发送邀请。您可以从同一对话框中删除协作者或退出共享笔记。</string>
    <string name="help_item_ai_assistant_title">使用 AI 助手</string>
    <string name="help_item_ai_assistant_steps">在“设置”中启用 AI 助手（需要下载模型）。\n打开笔记并点击魔棒按钮。\n输入请求，或点击麦克风直接交谈。\n助手可以进行摘要、自动打标签、安排提醒等操作。</string>
    <string name="help_item_tags_title">使用标签整理笔记</string>
    <string name="help_item_tags_steps">打开笔记并点击“更多”菜单（三个点）。\n点击“添加标签”，选择现有标签或创建一个新标签。\n使用侧边抽屉浏览按标签筛选的笔记。</string>
    <string name="help_item_export_pdf_title">将笔记导出为 PDF</string>
    <string name="help_item_export_pdf_steps">打开笔记。\n点击“更多”菜单（三个点）。\n点击“导出为 PDF”。\n选择分享或保存生成文件的地方。</string>
    <string name="help_item_pin_widget_title">将笔记固定为桌面小部件</string>
    <string name="help_item_pin_widget_steps">打开笔记。\n点击“更多”菜单（三个点），然后点击“固定为小部件”。\n确认桌面上的放置位置。\n笔记将以“单个笔记”小部件的形式出现。</string>
    <string name="help_item_backup_restore_title">通过 Google 云端硬盘备份和恢复</string>
    <string name="help_item_backup_restore_steps">打开“设置”并使用 Google 登录。\n开启自动备份并选择频率。\n使用“立即备份”进行即时备份，或使用“立即恢复”恢复以前的版本。</string>
    <string name="help_item_cloud_sync_title">启用跨设备云同步</string>
    <string name="help_item_cloud_sync_steps">从“设置”或抽屉中使用 Google 登录。\n在“设置”中开启 CloudSync。\n您的笔记将在已登录设备之间实时同步（媒体文件不进行同步）。</string>

    <string name="setting_delete_cloud_data_title">删除所有云数据</string>
    <string name="setting_delete_cloud_data_subtitle">从 CloudSync 中删除您的笔记以及从 Google 云端硬盘中删除所有备份。保存在此设备上的本地笔记将被保留。</string>
    <string name="dialog_delete_cloud_data_title">删除所有云数据？</string>
    <string name="dialog_delete_cloud_data_description">这将永久从 CloudSync (Supabase) 和 Google 云端硬盘中删除您的笔记、标签和备份。其他用户与您共享的笔记以及保存在此设备上的本地笔记不受影响。此操作无法撤销。</string>
