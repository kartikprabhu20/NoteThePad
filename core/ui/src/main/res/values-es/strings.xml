    <!-- Permission Rationale -->
    <string name="permission_notification_title">Permiso de notificación</string>
    <string name="permission_notification_msg">Usamos notificaciones para mostrarte el progreso de la carga. Sin esto, no sabrás si la copia de seguridad finaliza con éxito mientras la aplicación está en segundo plano.</string>
    <string name="permission_camera_title">Permiso de cámara</string>
    <string name="permission_camera_msg">Usamos la cámara para añadir imágenes y vídeos a tus notas. Sin esto, no podrás adjuntar fotos/vídeos directamente, sino desde la galería.</string>
    <string name="permission_microphone_title">Permiso de micrófono</string>
    <string name="permission_microphone_msg">Usamos el micrófono para grabar y adjuntar notas de voz. Sin esto, no podrás crear notas de voz.</string>
    <string name="permission_camera_denied_title">Se requiere permiso de cámara</string>
    <string name="permission_camera_denied_msg">Has denegado permanentemente el acceso a la cámara. Para tomar fotos para tus notas, por favor actívalo en los ajustes de la aplicación.</string>
    <string name="permission_microphone_denied_title">Se requiere permiso de micrófono</string>
    <string name="permission_microphone_denied_msg">Has denegado permanentemente el acceso al micrófono. Para grabar notas de voz, por favor actívalo en los ajustes de la aplicación.</string>

