    <!-- Permission Rationale -->
    <string name="permission_notification_title">알림 권한</string>
    <string name="permission_notification_msg">업로드 진행 상황을 보여주기 위해 알림을 사용합니다. 알림이 없으면 앱이 백그라운드에 있을 때 백업이 성공적으로 완료되었는지 알 수 없습니다.</string>
    <string name="permission_camera_title">카메라 권한</string>
    <string name="permission_camera_msg">메모 항목에 이미지와 비디오를 추가하기 위해 카메라를 사용합니다. 카메라가 없으면 갤러리에서 첨부하는 대신 직접 이미지/비디오를 첨부할 수 없습니다.</string>
    <string name="permission_microphone_title">마이크 권한</string>
    <string name="permission_microphone_msg">음성 메모를 녹음하고 첨부하기 위해 마이크를 사용합니다. 마이크가 없으면 음성 메모를 생성할 수 없습니다.</string>
    <string name="permission_camera_denied_title">카메라 권한 필요</string>
    <string name="permission_camera_denied_msg">카메라 액세스를 영구적으로 거부했습니다. 메모용 사진을 찍으려면 앱 설정에서 활성화하세요.</string>
    <string name="permission_microphone_denied_title">마이크 권한 필요</string>
    <string name="permission_microphone_denied_msg">마이크 액세스를 영구적으로 거부했습니다. 음성 메모를 녹음하려면 앱 설정에서 활성화하세요.</string>

